{
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "nodeVersion": "20.x",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/parse-workout.ts": { "maxDuration": 30 },
    "api/upload-workout.ts": { "maxDuration": 30 },
    "api/debug.ts": { "maxDuration": 10 }
  }
}
